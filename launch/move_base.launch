<launch>
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <param name="base_global_planner" value="global_planner/GlobalPlanner"/>
    <rosparam file="$(find diff_drive_robot)/config/global_planner_params.yaml" command="load" />

    <remap from="cmd_vel" to="/three_wheel_diff_drive/cmd_vel"/>

    <remap from="odom" to="/odom"/> 

    <remap from="scan" to="/three_wheel_diff_drive/scan"/>

    <rosparam file="$(find diff_drive_robot)/config/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find diff_drive_robot)/config/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find diff_drive_robot)/config/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find diff_drive_robot)/config/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find diff_drive_robot)/config/base_local_planner_params.yaml" command="load" />
  </node>
</launch>
